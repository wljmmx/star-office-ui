# Star Office UI - Environment Configuration Template
# 
# Copy this file to .env and configure the values for your environment.
# DO NOT commit .env files to version control!
#
# Usage:
#   cp .env.template .env
#   # Edit .env with your configuration
#   docker-compose up --build

# =============================================================================
# Flask Application Configuration
# =============================================================================

# Flask secret key for session management and security
# Generate a new key using: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be at least 32 characters with uppercase, lowercase, digits, and special characters
FLASK_SECRET_KEY="your-generated-secret-key-here-minimum-32-chars"

# =============================================================================
# Server Configuration
# =============================================================================

# Debug mode (true/false) - Set to false in production
SOUI_DEBUG=false

# Host address to bind to
# 127.0.0.1 for local only, 0.0.0.0 for network access
SOUI_HOST=127.0.0.1

# Port number for the server
SOUI_PORT=5000

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://yourdomain.com
# In production, specify exact domains (no wildcards)
SOUI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Session/Cookie Configuration
# =============================================================================

# Whether to set Secure flag on session cookies (true/false)
# Should be true when using HTTPS
SOUI_COOKIE_SECURE=false

# =============================================================================
# Synchronization Configuration
# =============================================================================

# Interval in seconds for background sync service
# Lower values = more frequent updates but higher resource usage
SOUI_SYNC_INTERVAL=5

# =============================================================================
# Database Configuration
# =============================================================================

# Database path is automatically resolved based on project structure
# Default: skills/github-collab/github-collab.db
# Alternative: ../skills/github-collab/github-collab.db
# No environment variable needed - uses Config.DATABASE_PATH

# =============================================================================
# Docker-specific Configuration (when using docker-compose)
# =============================================================================

# These are typically set in docker-compose.yml but can be overridden here:
# DATABASE_PATH=/data/github-collab.db
# DEBUG=false
# HOST=0.0.0.0
# PORT=5000

# =============================================================================
# Security Notes
# =============================================================================
#
# 1. NEVER commit .env files to version control
# 2. Generate a unique FLASK_SECRET_KEY for each environment
# 3. Use strong secrets (32+ characters with mixed case, numbers, symbols)
# 4. In production, restrict CORS_ORIGINS to specific domains only
# 5. Enable SOUI_COOKIE_SECURE when using HTTPS
# 6. Set SOUI_DEBUG=false in production to disable debug features
#
# =============================================================================
# Example Production Configuration
# =============================================================================
#
# FLASK_SECRET_KEY="aB3$dE6#gI9*jL2@mN5+pQ8-rS1=tU4!vW7^x"
# SOUI_DEBUG=false
# SOUI_HOST=0.0.0.0
# SOUI_PORT=5000
# SOUI_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
# SOUI_COOKIE_SECURE=true
# SOUI_SYNC_INTERVAL=10
#
# =============================================================================
