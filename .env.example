# =============================================================================
# Star Office UI - 环境配置示例
# Star Office UI Environment Configuration Example
# =============================================================================
# 说明：
# 1. 复制此文件为 .env 文件：cp .env.example .env
# 2. 根据实际情况修改配置值
# 3. 带 * 标记的为必需配置项
# =============================================================================

# =============================================================================
# 1. 应用配置 (Application Configuration)
# =============================================================================

# * 运行环境：development (开发) / production (生产)
# Required: Yes
FLASK_ENV=development

# Flask 调试模式：true (开启) / false (关闭)
# 生产环境建议关闭
# Required: Yes
FLASK_DEBUG=false

# * 密钥：用于会话加密、CSRF 保护等
# 生产环境请替换为强随机字符串（至少 32 位）
# Required: Yes
SECRET_KEY=your-secret-key-change-in-production

# =============================================================================
# 2. 数据库配置 (Database Configuration)
# =============================================================================

# * 数据库文件路径（相对路径或绝对路径）
# Required: Yes
DATABASE_PATH=./data/star-office.db

# 数据库连接池大小
# 默认：5
# Required: No
DB_POOL_SIZE=5

# 数据库连接超时时间（秒）
# 默认：30
# Required: No
DB_TIMEOUT=30

# =============================================================================
# 3. 服务器配置 (Server Configuration)
# =============================================================================

# * 服务器监听地址
# 0.0.0.0 表示监听所有网络接口
# 开发环境建议使用 127.0.0.1
# Required: Yes
HOST=0.0.0.0

# * 服务器端口
# Required: Yes
PORT=5000

# Gunicorn 工作进程数（生产环境使用）
# 建议设置为 CPU 核心数 * 2 + 1
# Required: No
WORKERS=4

# =============================================================================
# 4. Socket.IO 配置 (Socket.IO Configuration)
# =============================================================================

# Socket.IO 异步模式：eventlet / gevent / threading
# 推荐生产环境使用 eventlet 或 gevent
# Required: No
SOCKET_IO_ASYNC_MODE=eventlet

# 允许的跨域源（多个来源用逗号分隔）
# * 表示允许所有来源（仅开发环境）
# 生产环境应指定具体域名
# Required: No
CORS_ORIGINS=*

# =============================================================================
# 5. 日志配置 (Logging Configuration)
# =============================================================================

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
# 开发环境建议使用 DEBUG，生产环境建议使用 INFO 或 WARNING
# Required: No
LOG_LEVEL=DEBUG

# 日志文件路径
# 留空则仅输出到控制台
# Required: No
LOG_FILE=./logs/star-office.log

# =============================================================================
# 6. 功能开关 (Feature Flags)
# =============================================================================

# 启用自动同步功能
# true (开启) / false (关闭)
# Required: No
ENABLE_AUTO_SYNC=true

# 启用智能体自动创建功能
# true (开启) / false (关闭)
# Required: No
ENABLE_AGENT_SPAWNING=true

# 最大并发智能体数量
# 根据服务器性能调整
# Required: No
MAX_CONCURRENT_AGENTS=10

# =============================================================================
# 7. 路径配置 (Path Configuration)
# =============================================================================

# * 技能目录路径（存放 Agent Skills）
# Required: Yes
SKILLS_DIR=./skills

# 静态资源目录路径
# Required: No
ASSETS_DIR=./assets

# * 备份目录路径
# Required: Yes
BACKUP_DIR=./backups

# =============================================================================
# 安全提示 (Security Notes)
# =============================================================================
# - 切勿将 .env 文件提交到版本控制系统
# - 生产环境必须修改 SECRET_KEY
# - 生产环境应限制 CORS_ORIGINS 为具体域名
# - 定期备份数据库和重要配置
# =============================================================================
