# Star Office UI - Environment Configuration
# Copy this file to .env and configure for your environment

# ===========================================
# Flask Configuration
# ===========================================
# SECRET_KEY: Must be at least 32 characters with uppercase, lowercase, digit, and special character
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=your-super-secret-key-min-32-chars-with-special

# Debug mode: true for development, false for production
SOUI_DEBUG=false

# ===========================================
# Server Configuration
# ===========================================
# Host: 0.0.0.0 for production (all interfaces), 127.0.0.1 for development
SOUI_HOST=0.0.0.0

# Port: Default 5000
SOUI_PORT=5000

# ===========================================
# CORS Configuration
# ===========================================
# CORS_ORIGINS: Comma-separated list of allowed origins (no wildcards in production)
# Example: SOUI_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
SOUI_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ===========================================
# JWT Authentication Configuration
# ===========================================
# JWT_SECRET_KEY: Secret key for JWT token signing (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-with-special

# ===========================================
# WebSocket/Sync Configuration
# ===========================================
# SYNC_INTERVAL: Sync interval in seconds (1-60, default 5)
SOUI_SYNC_INTERVAL=5

# ===========================================
# Database Configuration
# ===========================================
# DATABASE_PATH: Path to SQLite database
SOUI_DATABASE_PATH=./backend/skills/github-collab/github-collab.db

# ===========================================
# Security Configuration
# ===========================================
# SESSION_COOKIE_SECURE: true if using HTTPS, false for HTTP
SOUI_COOKIE_SECURE=false

# ===========================================
# Logging Configuration
# ===========================================
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
SOUI_LOG_LEVEL=INFO

# LOG_FILE_PATH: Path to log file (for file output)
SOUI_LOG_FILE_PATH=/var/log/star-office/app.log

# ===========================================
# Frontend Configuration
# ===========================================
# FRONTEND_DIR: Path to frontend static files
SOUI_FRONTEND_DIR=./frontend
